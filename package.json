{
  "name": "js-routes",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:railsware/js-routes.git",
  "author": "Bogdan Gusiev <agresso@gmail.com>, Alexey Vasiliev <https://leopard.in.ua> ",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pinst": "^3.0.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "build": "tsc && yarn lint:fix",
    "lint:fix": "yarn eslint --fix && yarn prettier --write lib/routes.ts"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn lint:fix"
    }
  },
  "lint-staged": {
    "./lib/routes.ts": [
      "yarn lint:fix"
    ]
  },
  "packageManager": "yarn@4.5.3"
}
